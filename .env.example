PORT=3000
BIND_HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1

# Local development fallback. Do not use this as production OAuth.
AUTH_REQUIRED=true
DEV_BEARER_TOKEN=replace-with-a-local-test-token

# Production OAuth/OIDC token verification.
# OAUTH_ISSUER_URL=https://your-tenant.example.com/
# OAUTH_AUDIENCE=https://your-host.example.com/mcp
# OAUTH_JWKS_URL=https://your-tenant.example.com/.well-known/jwks.json
REQUIRED_SCOPES=amazon-drive-image-tool:write

# Google Drive.
DEFAULT_PARENT_FOLDER_ID=1bH22h21qlMyaROq748jJy0JuC2s3kuBg
GOOGLE_DRIVE_SCOPE=https://www.googleapis.com/auth/drive
# GOOGLE_SERVICE_ACCOUNT_KEY_FILE=/secrets/service-account.json
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Amazon extraction and batch limits.
MAX_URLS_PER_RUN=20
MAX_IMAGES_PER_PRODUCT=20
MAX_CONCURRENT_PRODUCTS=5
EXTRACTOR_TIMEOUT_MS=45000
# SCRAPING_API_URL=https://optional-fallback.example.com/extract
# SCRAPING_API_TOKEN=optional-token
