{
  "name": "amazon-drive-image-tool",
  "version": "0.1.0",
  "description": "OAuth-protected MCP server that extracts Amazon UAE product gallery images and uploads new files to Google Drive.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.19.2",
    "google-auth-library": "^9.15.1",
    "googleapis": "^144.0.0",
    "jose": "^5.10.0",
    "playwright": "^1.52.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
